{
  "name": "private-mind",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "download-models": "node -e \"require('./scripts/download-models.js').ensureModelAssets()\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|zustand)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "\\.svg$": "<rootDir>/__mocks__/svgMock.tsx",
      "^react-native-device-info$": "<rootDir>/__mocks__/react-native-device-info.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/async-storage.ts",
      "^react-native-pdfium$": "<rootDir>/__mocks__/react-native-pdfium.ts",
      "^expo-file-system$": "<rootDir>/__mocks__/expo-file-system.ts",
      "^react-native-executorch$": "<rootDir>/__mocks__/react-native-executorch.ts",
      "^@dr.pogodin/react-native-fs$": "<rootDir>/__mocks__/react-native-fs.ts",
      "^react-native-toast-message$": "<rootDir>/__mocks__/react-native-toast-message.ts",
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.ts",
      "^react-native-audio-api$": "<rootDir>/__mocks__/react-native-audio-api.ts",
      "^@react-native-clipboard/clipboard$": "<rootDir>/__mocks__/@react-native-clipboard/clipboard.ts",
      "^react-native-markdown-display$": "<rootDir>/__mocks__/react-native-markdown-display.tsx",
      "^@gorhom/bottom-sheet$": "<rootDir>/__mocks__/@gorhom/bottom-sheet.tsx"
    }
  },
  "op-sqlite": {
    "libsql": true
  },
  "dependencies": {
    "@dr.pogodin/react-native-fs": "^2.35.1",
    "@expo-google-fonts/dm-sans": "^0.4.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@op-engineering/op-sqlite": "^15.2.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-rag/executorch": "^0.8.0",
    "@react-native-rag/op-sqlite": "^0.8.0",
    "@react-native/metro-config": "^0.76.3",
    "@react-navigation/drawer": "^7.5.6",
    "@swmansion/react-native-detour": "^0.4.0",
    "expo": "^54.0.0",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.20",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "metro-config": "^0.81.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-api": "^0.11.7",
    "react-native-device-info": "^15.0.1",
    "react-native-enriched-markdown": "^0.4.1",
    "react-native-executorch": "^0.8.0",
    "react-native-executorch-expo-resource-fetcher": "^0.8.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-loading-spinner-overlay": "^3.0.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pdfium": "file:./react-native-pdfium-0.1.3.tgz",
    "react-native-rag": "^0.8.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-toast-message": "^2.3.0",
    "react-native-wheel-scrollview-picker": "^2.0.6",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
